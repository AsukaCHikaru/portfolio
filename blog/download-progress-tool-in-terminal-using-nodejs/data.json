{"data":{"metadata":{"title":"Download Progress Tool in Terminal Using Node.JS","publishedAt":"2019-06-07","pathname":"download-progress-tool-in-terminal-using-nodejs","category":"note","topic":"programming","language":"en-US","featured":false},"content":[{"type":"heading","level":1,"body":[{"type":"textBody","value":"TL;DR:","style":"plain"}]},{"type":"list","ordered":false,"items":[{"type":"listItem","body":[{"type":"textBody","style":"code","value":"fs.stat"},{"type":"textBody","value":" for getting file size","style":"plain"}]},{"type":"listItem","body":[{"type":"textBody","value":"readline.clearLine","style":"code"}]},{"type":"listItem","body":[{"type":"textBody","value":"readline.cursorTo(0)","style":"code"}]},{"type":"listItem","body":[{"type":"textBody","value":"process.stdout.write","style":"code"}]}]},{"type":"paragraph","body":[{"type":"textBody","value":"Combine these 3 to update command line instead of printing new line","style":"plain"}]},{"type":"heading","level":1,"body":[{"type":"textBody","value":"Get file size","style":"plain"}]},{"type":"paragraph","body":[{"type":"textBody","style":"code","value":"fs.stat"},{"type":"textBody","value":" returns an object contains several stats of the file from url you're downloading.","style":"plain"}]},{"type":"paragraph","body":[{"type":"link","body":[{"type":"textBody","value":"Detailed explanation of fs.stat","style":"plain"}],"url":"https://nodejs.org/api/fs.html#fs_class_fs_stats"},{"type":"textBody","value":".","style":"plain"}]},{"type":"paragraph","body":[{"type":"textBody","style":"plain","value":"Inside of the object, there is "},{"type":"textBody","style":"code","value":"size"},{"type":"textBody","value":" property, which is obviously the size of file, in bytes.","style":"plain"}]},{"type":"code","lang":"js","body":"let fileSize = 0;\nfs.stat(\"url/to/your/file\", (stats) => {\n  fileSize = stats.size;\n});"},{"type":"heading","level":1,"body":[{"type":"textBody","value":"Get current progression","style":"plain"}]},{"type":"paragraph","body":[{"type":"textBody","style":"plain","value":"In the response from "},{"type":"textBody","style":"code","value":"https.get"},{"type":"textBody","style":"plain","value":" when downloading, track and add up the total length of chunks piped into "},{"type":"textBody","style":"code","value":"fs.writeStream"},{"type":"textBody","value":". This total length devided by file size is the download progression we need.","style":"plain"}]},{"type":"heading","level":1,"body":[{"type":"textBody","value":"Write to terminal, but in same line","style":"plain"}]},{"type":"paragraph","body":[{"type":"textBody","style":"code","value":"console.log"},{"type":"textBody","value":" ","style":"plain"},{"type":"link","body":[{"type":"textBody","value":"implementation","style":"plain"}],"url":"https://nodejs.org/docs/v0.3.1/api/process.html#process.stdout"},{"type":"textBody","style":"plain","value":" in Node is actually based on "},{"type":"textBody","style":"code","value":"process.stdout.write"},{"type":"textBody","style":"plain","value":". But since there's a "},{"type":"textBody","style":"code","value":"\\\\n"},{"type":"textBody","style":"plain","value":" at end of every "},{"type":"textBody","style":"code","value":"console.log"},{"type":"textBody","style":"plain","value":", new line is printed everytime instead of being updated. Therefore we can't use "},{"type":"textBody","value":"console.log","style":"code"}]},{"type":"paragraph","body":[{"type":"textBody","style":"plain","value":"By combine "},{"type":"textBody","style":"code","value":"readline.clearLine"},{"type":"textBody","style":"plain","value":" and "},{"type":"textBody","style":"code","value":"readline.cursorTo(0)"},{"type":"textBody","style":"plain","value":", terminal will erase the last line of currently printed line, then move cursor to the starting position. Then we can use "},{"type":"textBody","style":"code","value":"process.stdout.write"},{"type":"textBody","style":"plain","value":" to print out current progress without "},{"type":"textBody","style":"code","value":"\\\\n"},{"type":"textBody","style":"plain","value":" in "},{"type":"textBody","style":"code","value":"console.log"},{"type":"textBody","value":" implementation that causes changing line.","style":"plain"}]},{"type":"code","lang":"js","body":"let progress = 0;\nlet req = https.get(\"url/to/your/file\", (res, err) => {\n  res.on(\"data\", (chunk) => {\n    progress += chunk.length;\n    const dlPercentage = ((progress / fileSize) * 100).toFixed(2);\n    readline.clearLine();\n    readline.cursorTo(0);\n    process.stdout.write(`Downloading... ${dlPercentage}%`);\n  });\n});"}]}}